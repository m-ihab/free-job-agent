# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# France Travail API (free — request access at francetravail.io/partenaire)
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_SCOPE=api_offresdemploiv2 o2dsoffre

# Optional: GitHub personal access token (increases API rate limit from 60 to 5000/hr)
GITHUB_TOKEN=

# Optional: Ollama configuration overrides
# OLLAMA_HOST=http://localhost:11434
# JOB_AGENT_OLLAMA_MODEL=mistral
# JOB_AGENT_OLLAMA_FAST_MODEL=mistral:7b

# Optional: override profile/data directories
# JOB_AGENT_DATA_DIR=~/.job_agent
# JOB_AGENT_PROFILES_DIR=~/my-profiles
