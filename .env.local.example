# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# France Travail API (free — request access at francetravail.io/partenaire)
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_SCOPE=api_offresdemploiv2 o2dsoffre

# Optional: GitHub personal access token (increases API rate limit from 60 to 5000/hr)
GITHUB_TOKEN=

# Optional: Ollama configuration overrides
# OLLAMA_HOST=http://localhost:11434
# JOB_AGENT_OLLAMA_MODEL=mistral
# JOB_AGENT_OLLAMA_FAST_MODEL=mistral:7b

# Optional: override profile/data directories
# JOB_AGENT_DATA_DIR=~/.job_agent
# JOB_AGENT_PROFILES_DIR=~/my-profiles

# Optional: free-tier cloud LLM fallback (JOB-PUBLIC tasks only — classify/summarize.
# Candidate data NEVER leaves the machine; see src/job_agent/llm_providers.py.)
# Opt in explicitly, then add any keys you have. All tiers below are free.
# JOB_AGENT_USE_FREE_LLM=1
# GROQ_API_KEY=            # console.groq.com — Llama 3.3 70B, ~1k req/day
# MISTRAL_API_KEY=         # console.mistral.ai — free Experiment plan (opts into data training)
# CEREBRAS_API_KEY=        # cloud.cerebras.ai — gpt-oss-120b, ~1M tokens/day
# GEMINI_API_KEY=          # aistudio.google.com — Gemma 3 27B, 14.4k req/day (EEA: not used for training)
# JOB_AGENT_FREE_LLM_ORDER=groq,mistral,cerebras,gemini
# JOB_AGENT_FREE_LLM_TIMEOUT=30
# JOB_AGENT_FREE_LLM_MODEL_GROQ=llama-3.3-70b-versatile
